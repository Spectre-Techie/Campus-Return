# Render production environment for server service
# Replace all placeholder values before deployment.

NODE_ENV=production
PORT=10000

# Use Supabase transaction pooler with PgBouncer compatibility.
DATABASE_URL=postgresql://postgres:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=45
DIRECT_URL=postgresql://postgres:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=45
DATABASE_CONNECTION_LIMIT=5
DATABASE_POOL_TIMEOUT=45

# Clerk (user requested to keep dev keys for deployment)
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXX
CLERK_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# Must match deployed Vercel URL (without trailing slash)
FRONTEND_URL=https://campus-return.vercel.app

# Optional comma-separated origins (for preview URLs)
CORS_ALLOWED_ORIGINS=https://campus-return.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
